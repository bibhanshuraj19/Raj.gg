{
  "name": "raj-gg",
  "version": "1.0.0",
  "private": true,
  "main": "./dist-electron/main.js",
  "scripts": {
    "dev": "next dev -p 3070",
    "build": "next build",
    "start": "next start -p 3070",
    "lint": "next lint",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "app:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3070 && npm run electron:dev\"",
    "app:build": "npm run electron:build"
  },
  "build": {
    "appId": "com.rajgg.portfolio",
    "productName": "Raj.gg",
    "files": [
      "out/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.30",
    "lucide-react": "^0.438.0",
    "next": "^16.2.1",
    "next-seo": "^6.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-fast-marquee": "^1.6.4",
    "react-intersection-observer": "^9.5.3",
    "react-responsive-carousel": "^3.2.23",
    "tailwind-merge": "^2.5.2",
    "typewriter-effect": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.1"
  }
}
